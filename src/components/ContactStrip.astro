---
import { CONTACT } from '../consts';
---
<section class="section bg-soft">
  <div class="container text-center">
    <h2 class="underline center">Investment Intelligence</h2>
    <p style="max-width:720px; margin:18px auto 32px; font-size:1.1rem;">
      Custom portfolios and financial plans for individual investors. Institutional-quality investment research and portfolio management — at a fraction of the cost.
    </p>
    <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
      <a href={CONTACT.phoneHref} class="btn btn-primary">📞 {CONTACT.phone}</a>
      <a href={CONTACT.emailHref} class="btn btn-accent">✉ {CONTACT.email}</a>
    </div>
  </div>
</section>

---
import { SITE, CONTACT, DISCLOSURE, SOCIAL } from '../consts';
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <img src="/logo-footer.png" alt="Wilco Financial" />
        <p style="margin-top: 16px; max-width: 340px;">
          Wilco charges a simple, transparent fee of <strong>{SITE.fee} per year</strong> of managed assets. Our interests are aligned with yours — your portfolio's growth is not held back by excessive, hidden fees.
        </p>
      </div>
      <div>
        <h5>Quick Links</h5>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/services">Services</a></li>
          <li><a href="/southwest-airlines">SWA Pilots & Employees</a></li>
          <li><a href="/articles">Articles</a></li>
          <li><a href="/faq">FAQ</a></li>
          <li><a href="/form-adv">Form ADV</a></li>
        </ul>
      </div>
      <div>
        <h5>Contact</h5>
        <ul>
          <li><a href={CONTACT.phoneHref}>{CONTACT.phone}</a></li>
          <li><a href={CONTACT.emailHref}>{CONTACT.email}</a></li>
          <li style="margin-top:10px">
            {CONTACT.addressLine1}, {CONTACT.addressLine2}<br />
            {CONTACT.city}, {CONTACT.state} {CONTACT.zip}
          </li>
          <li style="margin-top:10px">{CONTACT.hours}</li>
        </ul>
      </div>
      <div>
        <h5>Get Started</h5>
        <ul>
          <li><a href="/contact">Contact Us</a></li>
          <li><a href={CONTACT.calendlyUrl} target="_blank" rel="noopener">Schedule a Meeting</a></li>
          <li><a href="/fees">Our Fees</a></li>
          <li><a href="/fiduciary">Fiduciary Standard</a></li>
        </ul>
        {SOCIAL.linkedin && (
          <div style="margin-top:20px;">
            <a href={SOCIAL.linkedin} target="_blank" rel="noopener" aria-label="Jon Gillett on LinkedIn" class="social-icon-link">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          </div>
        )}
      </div>
    </div>
    <p class="footer-disclosure">{DISCLOSURE}</p>
    <p class="footer-copy">© {year} {SITE.legalName}. All rights reserved. · <a href="/privacy">Privacy</a> · <a href="/terms">Terms</a></p>
  </div>
</footer>

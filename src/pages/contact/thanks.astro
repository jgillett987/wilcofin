---
import PageLayout from '../../layouts/PageLayout.astro';
import { CONTACT, SITE } from '../../consts';
---
<PageLayout
  title="Thanks for reaching out"
  description="Your message has been received. Wilco Financial will be in touch shortly."
  eyebrow="Contact"
  heroTitle="Message received — thank you."
  heroSubtitle="We'll be in touch shortly. In the meantime, feel free to keep reading or schedule a time to talk."
  breadcrumbs={[{ label: 'Contact', href: '/contact' }, { label: 'Thanks' }]}
  heroVideo="/videos/04.mp4"
  hideCTA={true}
>
  <section class="section">
    <div class="container narrow">
      <div class="card" style="padding:32px 28px;">
        <h2 style="margin-top:0;">What happens next</h2>
        <p style="font-size:1.05rem;">
          {SITE.advisorName} personally reviews every inquiry. You'll hear back
          within one business day — typically much sooner. If it's a fit, the next
          step is a short, no-pressure conversation to talk through what you're
          trying to accomplish.
        </p>
        <hr style="border:none; border-top:1px solid var(--border); margin:24px 0;" />
        <h3 style="margin-top:0;">Want to move faster?</h3>
        <p>
          You can put a time on the calendar right now — pick a slot that works for you:
        </p>
        <p style="margin-top:20px;">
          <a href={CONTACT.calendlyUrl} class="btn btn-primary" target="_blank" rel="noopener">Schedule a Meeting</a>
          <a href={CONTACT.phoneHref} class="btn btn-ghost" style="margin-left:10px;">Call {CONTACT.phone}</a>
        </p>
        <hr style="border:none; border-top:1px solid var(--border); margin:24px 0;" />
        <p style="margin:0; color:var(--muted); font-size:0.95rem;">
          While you're here, you might enjoy browsing our <a href="/articles" style="text-decoration:underline; color:var(--navy); font-weight:600;">articles</a> —
          plain-English pieces on fees, fiduciary duty, retirement tax planning, and the advisor-shopping questions that matter.
        </p>
      </div>
    </div>
  </section>
</PageLayout>

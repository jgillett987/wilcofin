---
// Static admin panel. List is rendered at build time for reliability.
// Edit form + GitHub save are client-side; PAT lives only in the user's
// browser localStorage. Edit view reuses the live site's global.css so the
// preview is visually identical to a published article.
import '../../styles/global.css';
import fs from 'node:fs';
import path from 'node:path';
import { parseFrontmatter } from '../../lib/admin';

const ROOT = process.cwd();
const ARTICLES_DIR = path.join(ROOT, 'src', 'content', 'articles');
const IMAGES_DIR = path.join(ROOT, 'public', 'images');
const VIDEOS_DIR = path.join(ROOT, 'public', 'videos');

const articles = fs.readdirSync(ARTICLES_DIR)
  .filter((f) => f.endsWith('.md'))
  .map((f) => {
    const raw = fs.readFileSync(path.join(ARTICLES_DIR, f), 'utf8');
    const { data, body } = parseFrontmatter(raw);
    return {
      slug: f.replace(/\.md$/, ''),
      title: data.title || f,
      description: data.description || '',
      pubDate: data.pubDate || '',
      author: data.author || 'Wilco Financial',
      tags: Array.isArray(data.tags) ? data.tags : [],
      heroImage: data.heroImage || '',
      heroVideo: data.heroVideo || '',
      body,
    };
  })
  .sort((a, b) => (b.pubDate || '').localeCompare(a.pubDate || ''));

const images = fs.readdirSync(IMAGES_DIR)
  .filter((f) => /\.(jpe?g|png|webp|gif|avif)$/i.test(f))
  .sort();

let videos: string[] = [];
try {
  videos = fs.readdirSync(VIDEOS_DIR)
    .filter((f) => /\.(mp4|webm|mov|m4v)$/i.test(f))
    .sort();
} catch {}

// Mirror the pool-and-hash logic used on the real article page so the admin
// preview shows the same auto-picked video when heroVideo is empty.
const HERO_POOL = [
  '/videos/00.mp4','/videos/01.mp4','/videos/02.mp4','/videos/03.mp4','/videos/04.mp4',
  '/videos/05.mp4','/videos/06.mp4','/videos/08.mp4','/videos/10.mp4','/videos/14.mp4',
];
const pickVideo = (slug: string) => {
  let h = 0;
  for (let i = 0; i < slug.length; i++) h = (h * 31 + slug.charCodeAt(i)) >>> 0;
  return HERO_POOL[h % HERO_POOL.length];
};
for (const a of articles) {
  (a as any).autoVideo = pickVideo(a.slug);
}

// Per-article data stored as JSON blocks keyed by slug (safely HTML-escaped
// via set:html inside <script type="application/json">). Avoids the "one giant
// inlined JSON" fragility.
const articlesBySlug: Record<string, any> = {};
for (const a of articles) articlesBySlug[a.slug] = a;

// Ordered slug list (same order as the list view — newest first). Used by
// the editor for prev/next keyboard navigation.
const orderedSlugs = articles.map((a) => a.slug);
const config = { repo: 'jgillett987/wilcofin', branch: 'main', images, videos, orderedSlugs };
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Admin · Wilco Financial</title>
  <style is:global>
    body{font:15px/1.5 -apple-system,Segoe UI,Roboto,sans-serif;margin:0;color:#1a2238;background:#f7f9fc}
    header{background:#011342;color:#fff;padding:14px 24px;display:flex;justify-content:space-between;align-items:center}
    header a,header button.linkish{color:#a2e37d;text-decoration:none;font-weight:600;background:none;border:none;cursor:pointer;font-size:inherit}
    main{max-width:1100px;margin:0 auto;padding:24px}
    h1{font-family:Georgia,serif;margin:0 0 16px;color:#011342}
    table{width:100%;border-collapse:collapse;background:#fff;border-radius:8px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.05);table-layout:fixed}
    th,td{padding:10px 14px;text-align:left;border-bottom:1px solid #e5e9f2;vertical-align:middle;overflow:hidden}
    th{background:#eef2f8;font-size:.85rem;text-transform:uppercase;letter-spacing:.05em}
    tr:last-child td{border-bottom:none}
    tbody tr[data-edit]{cursor:pointer;transition:background .12s}
    tbody tr[data-edit]:hover{background:#f3f7fd}
    tbody tr[data-edit]:hover .btn{background:#6aad4a}
    td.c-thumb{width:88px}
    td.c-date{width:130px;color:#5a6582;font-size:.85rem}
    td.c-act{width:90px;text-align:right}
    img.thumb{width:64px;height:40px;object-fit:cover;border-radius:4px;border:1px solid #e5e9f2;display:block}
    .btn{display:inline-block;padding:8px 16px;background:#81c460;color:#fff;border-radius:6px;text-decoration:none;font-weight:600;border:none;cursor:pointer;font-size:.9rem}
    .btn:hover{background:#6aad4a}
    .btn-secondary{background:#fff;color:#011342;border:1px solid #011342}
    .flash{padding:10px 14px;border-radius:6px;margin-bottom:16px}
    .flash.ok{background:#d8f0c6;border:1px solid #81c460;color:#2d5016}
    .flash.err{background:#fbd8d8;border:1px solid #c46060;color:#601616}
    .gate{max-width:520px;margin:80px auto;background:#fff;padding:28px;border-radius:10px;box-shadow:0 8px 32px rgba(0,0,0,.06)}
    .gate label{display:block;margin:14px 0 4px;font-weight:600;font-size:.9rem}
    .gate input{width:100%;padding:10px;border:1px solid #d7dce7;border-radius:6px;font-size:1rem;box-sizing:border-box;font-family:ui-monospace,Menlo,monospace}
    .gate .btn{margin-top:14px}
    .gate small{color:#5a6582;display:block;margin-top:12px;line-height:1.5}
    .gate small a{color:#011342;text-decoration:underline}
    form label{display:block;margin:14px 0 4px;font-weight:600;font-size:.9rem}
    form input[type=text],form input[type=date],form textarea{width:100%;padding:8px 10px;border:1px solid #d7dce7;border-radius:6px;font-family:inherit;font-size:.95rem;box-sizing:border-box}
    form textarea[name=body]{min-height:360px;font-family:ui-monospace,Menlo,monospace;font-size:13px}
    form textarea[name=description]{min-height:60px}
    .row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px}
    .media-current{display:flex;align-items:center;gap:14px;background:#fff;border:1px solid #d7dce7;border-radius:8px;padding:10px 14px}
    .media-current .preview{width:140px;height:90px;object-fit:cover;border-radius:6px;background:#eef2f8;flex-shrink:0}
    .media-current .empty{display:flex;align-items:center;justify-content:center;color:#5a6582;font-size:.85rem}
    .media-current .path{flex:1;color:#5a6582;font-family:ui-monospace,Menlo,monospace;font-size:.85rem;word-break:break-all}
    .media-current .actions-inline{display:flex;gap:8px;flex-shrink:0}
    .actions{margin-top:20px;display:flex;gap:10px}
    .hidden{display:none !important}
    /* Edit view overlay — thin layer on top of global.css so the preview
       looks exactly like a published article. */
    #editView main,
    main:has(#editView:not(.hidden)){padding:0;max-width:none}
    #editView .admin-wrap{max-width:none;margin:0;padding:0}
    /* Sticky top action bar */
    .ae-top-bar{position:sticky;top:0;z-index:40;background:rgba(255,255,255,0.96);backdrop-filter:saturate(1.2) blur(6px);border-bottom:1px solid #e5e9f2;padding:10px 24px;display:flex;gap:10px;justify-content:space-between;align-items:center}
    .ae-top-bar .left,.ae-top-bar .right{display:flex;gap:10px;align-items:center}
    .ae-top-bar .hint{color:#5a6582;font-size:.82rem}
    .ae-top-bar .hint kbd{background:#eef2f8;border:1px solid #d7dce7;border-radius:4px;padding:1px 5px;font-family:ui-monospace,Menlo,monospace;font-size:.78rem}
    /* Edit affordances over the live layout */
    [contenteditable=true]{outline:none}
    [contenteditable=true]:hover{background:rgba(162,227,125,0.18);border-radius:4px;box-shadow:0 0 0 4px rgba(162,227,125,0.18)}
    [contenteditable=true]:focus{background:rgba(255,255,255,0.08);border-radius:4px;box-shadow:0 0 0 4px rgba(129,196,96,0.5)}
    .page-hero [contenteditable=true]:hover,.page-hero [contenteditable=true]:focus{background:rgba(255,255,255,0.08)}
    [contenteditable=true][data-placeholder]:empty::before{content:attr(data-placeholder);color:rgba(180,180,180,0.6);font-style:italic}
    .page-hero [contenteditable=true][data-placeholder]:empty::before{color:rgba(255,255,255,0.45)}
    /* Click-to-change hotspots on the video + image. The hero itself is the
       click target; the .container raises the title/desc above it so text
       editing doesn't trigger the video picker. */
    .page-hero{cursor:pointer}
    .page-hero .container{position:relative;z-index:4;cursor:auto}
    .page-hero .container *{cursor:auto}
    .page-hero [contenteditable=true]{cursor:text}
    .page-hero a{cursor:pointer}
    .ae-video-hint{position:absolute;top:16px;right:16px;background:rgba(1,19,66,0.75);color:#fff;padding:6px 12px;border-radius:999px;font-size:.78rem;font-weight:600;opacity:0;transition:opacity .15s;pointer-events:none;z-index:5}
    .page-hero:hover .ae-video-hint{opacity:1}
    .article-hero-float{cursor:pointer;position:relative}
    .article-hero-float:hover{outline:3px solid #81c460;outline-offset:3px}
    .ae-img-hint{position:absolute;top:8px;right:8px;background:rgba(1,19,66,0.75);color:#fff;padding:5px 10px;border-radius:999px;font-size:.75rem;font-weight:600;opacity:0;pointer-events:none;transition:opacity .15s;z-index:2}
    .ae-img-wrap:hover .ae-img-hint{opacity:1}
    .ae-img-wrap{float:right;width:42%;max-width:420px;margin:8px 0 28px 64px;position:relative}
    .ae-img-wrap .article-hero-float{float:none;width:100%;max-width:none;margin:0}
    .ae-img-wrap.empty{background:#eef2f8;border:2px dashed #b5bdd1;border-radius:12px;min-height:220px;display:flex;align-items:center;justify-content:center;color:#5a6582;font-weight:600;text-align:center;padding:20px;cursor:pointer}
    .ae-img-wrap.empty:hover{background:#dde4ef;border-color:#81c460;color:#011342}
    @media (max-width: 720px){
      .ae-img-wrap{float:none;width:100%;max-width:100%;margin:0 0 24px 0}
    }
    /* Plain contenteditable body that still looks like a rendered article */
    .ae-body-edit{min-height:400px}
    .ae-body-edit:focus{outline:none}
    .ae-video-note{display:inline-block;margin-left:10px;color:#5a6582;font-size:.78rem;font-style:italic}
    /* Modal picker */
    .modal-backdrop{position:fixed;inset:0;background:rgba(1,19,66,0.85);z-index:1000;display:flex;flex-direction:column}
    .modal-head{display:flex;justify-content:space-between;align-items:center;padding:18px 28px;background:#011342;color:#fff;border-bottom:1px solid rgba(255,255,255,0.15)}
    .modal-head h2{margin:0;font-family:Georgia,serif;font-size:1.25rem;color:#fff}
    .modal-head button{background:rgba(255,255,255,0.15);color:#fff;border:none;border-radius:6px;padding:8px 14px;cursor:pointer;font-weight:600;font-size:.9rem}
    .modal-head button:hover{background:rgba(255,255,255,0.25)}
    .modal-body{flex:1;overflow:auto;padding:24px 28px;background:#f7f9fc}
    .modal-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:16px}
    .modal-tile{background:#fff;border:3px solid transparent;border-radius:8px;overflow:hidden;cursor:pointer;transition:transform .15s,box-shadow .15s;box-shadow:0 2px 8px rgba(0,0,0,0.06);display:block}
    .modal-tile:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,0.12)}
    .modal-tile.selected{border-color:#81c460;box-shadow:0 0 0 3px rgba(129,196,96,0.35)}
    .modal-tile .media{width:100%;height:160px;object-fit:cover;display:block;background:#eef2f8}
    .modal-tile .caption{padding:8px 12px;font-size:.8rem;color:#5a6582;word-break:break-all;text-align:center;border-top:1px solid #e5e9f2;background:#fff}
    .modal-tile.none .media{display:flex;align-items:center;justify-content:center;color:#5a6582;font-weight:600;font-size:1rem}
  </style>
</head>
<body>
  <header>
    <div><strong>Wilco Admin</strong> <span style="opacity:.6;font-size:.85rem">· article editor</span></div>
    <div>
      <button class="linkish" id="signOutBtn" style="margin-right:14px">Sign out</button>
      <a href="/">View site</a>
    </div>
  </header>
  <main>
    <div id="gate" class="gate hidden">
      <h1>Sign in</h1>
      <div id="gateFlash"></div>
      <form id="gateForm">
        <label>GitHub Personal Access Token</label>
        <input type="password" id="patInput" autocomplete="off" placeholder="github_pat_..." required />
        <button type="submit" class="btn">Sign in</button>
        <small>
          Stored only in this browser's localStorage. Sent only to GitHub when you save.<br /><br />
          <strong>How to create a token:</strong> <a href="https://github.com/settings/personal-access-tokens/new" target="_blank" rel="noopener">github.com/settings/personal-access-tokens/new</a> → Repository access: <code>jgillett987/wilcofin</code> only → Repository permissions → Contents: <strong>Read and write</strong>.
        </small>
      </form>
    </div>

    <div id="listView" class="hidden">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
        <h1 style="margin:0">Articles ({articles.length})</h1>
        <button type="button" class="btn" id="composeBtn">+ Compose article</button>
      </div>
      <div id="flash"></div>
      <table>
        <thead><tr><th></th><th>Title</th><th>Date</th><th></th></tr></thead>
        <tbody>
          {articles.map((a) => (
            <tr data-edit={a.slug} title="Click to edit">
              <td class="c-thumb">{a.heroImage && <img class="thumb" src={a.heroImage} alt="" loading="lazy" />}</td>
              <td><strong>{a.title}</strong><br /><span style="color:#5a6582;font-size:.85rem">{a.slug}</span></td>
              <td class="c-date">{a.pubDate}</td>
              <td class="c-act"><button class="btn" type="button" data-edit={a.slug}>Edit</button></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div id="editView" class="hidden">
      <form id="editForm">
        <input type="hidden" id="editSlug" />
        <input type="hidden" id="fTitle" />
        <input type="hidden" id="fDesc" />
        <input type="hidden" id="fHeroImage" name="heroImage" />
        <input type="hidden" id="fHeroVideo" name="heroVideo" />
        <input type="hidden" id="fBody" />

        <!-- Sticky top action bar -->
        <div class="ae-top-bar">
          <div class="left">
            <button type="button" class="btn btn-secondary" id="backBtn" title="Save and return to list (browser Back does the same)">← Back to list</button>
            <span class="hint">Click the <strong>video</strong>, <strong>photo</strong>, or any <strong>text</strong> to edit · <kbd>Esc</kbd> to cancel edits</span>
          </div>
          <div class="right">
            <div id="slugRow" class="hidden"><input type="text" id="fSlug" pattern="[a-z0-9-]+" placeholder="article-slug" style="padding:8px 10px;border:1px solid #d7dce7;border-radius:6px" /></div>
            <button type="button" class="btn btn-secondary" id="cancelBtn">Cancel</button>
            <button type="submit" class="btn" id="saveBtn">Save &amp; Deploy</button>
          </div>
        </div>

        <div id="editFlash" style="max-width:1200px;margin:12px auto 0;padding:0 24px"></div>

        <!-- HERO: mirrors src/pages/articles/[...slug].astro -->
        <section class="page-hero page-hero-with-video-bg" id="aeHero" title="Click the video background to change it">
          <video id="aeHeroVideo" class="page-hero-bg-video" autoplay muted loop playsinline preload="auto" aria-hidden="true"></video>
          <span class="ae-video-hint">🎬 Click to change video</span>
          <div class="container">
            <nav class="breadcrumb" aria-label="Breadcrumb">
              <a href="#" onclick="return false">Home</a> / <a href="#" onclick="return false">Articles</a> / <span id="aeCrumbTitle"></span>
            </nav>
            <span class="eyebrow" id="aeEyebrow" contenteditable="true" data-placeholder="Tag"></span>
            <h1 id="aeTitle" contenteditable="true" spellcheck="true" data-placeholder="Article title"></h1>
            <p id="aeDesc" contenteditable="true" spellcheck="true" data-placeholder="Short description for social + SEO"></p>
          </div>
        </section>

        <!-- BODY: mirrors the real article section -->
        <section class="section">
          <div class="article-container">
            <div class="article-meta-row">
              <div>
                <p class="article-meta" style="font-size:0.9rem;text-transform:uppercase;letter-spacing:0.06em;font-weight:700;color:var(--muted);margin-bottom:8px">
                  <span contenteditable="true" id="aeDateLabel" data-placeholder="Date"></span>
                  <span> · </span>
                  <span contenteditable="true" id="aeAuthorLabel" data-placeholder="Author">Wilco Financial</span>
                  <span class="ae-video-note" id="aeVideoNote"></span>
                </p>
                <p style="margin-bottom:0;font-size:0.9rem" contenteditable="true" id="aeTagsLabel" data-placeholder="Tags, comma separated"></p>
              </div>
              <div class="article-top-nav">
                <a href="#" class="article-top-nav-btn" id="aePrevBtn" onclick="return false" title="Older article (← arrow)">← Prev</a>
                <a href="#" class="article-top-nav-btn" id="aeNextBtn" onclick="return false" title="Newer article (→ arrow)">Next →</a>
                <a href="#" class="article-top-nav-btn" id="heroVideoChangeBtn" onclick="return false">🎬 Change video</a>
                <a href="#" class="article-top-nav-btn" id="heroVideoClearBtn" onclick="return false" title="Use auto-picked video">Remove video</a>
              </div>
            </div>

            <article class="article-body prose">
              <div class="ae-img-wrap" id="aeImgWrap">
                <img id="aeHeroImage" class="article-hero-float" alt="" />
                <span class="ae-img-hint">🖼 Click to change</span>
              </div>
              <div class="ae-body-edit" id="aeBody" contenteditable="true" spellcheck="true" data-placeholder="Write the article body here. Use paragraph breaks; click to add headings/bold; paste plain text…"></div>
            </article>
          </div>
        </section>

        <!-- Hidden secondary fields -->
        <div style="max-width:980px;margin:0 auto 40px;padding:0 24px;display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:14px;background:#fff;border:1px solid #e5e9f2;border-radius:10px;padding:16px 20px">
          <label style="font-size:.8rem;text-transform:uppercase;letter-spacing:.05em;color:#5a6582;font-weight:600">Publish date<input type="date" id="fDate" style="width:100%;padding:8px 10px;border:1px solid #d7dce7;border-radius:6px;margin-top:4px" /></label>
          <label style="font-size:.8rem;text-transform:uppercase;letter-spacing:.05em;color:#5a6582;font-weight:600">Author<input type="text" id="fAuthor" style="width:100%;padding:8px 10px;border:1px solid #d7dce7;border-radius:6px;margin-top:4px" /></label>
          <label style="font-size:.8rem;text-transform:uppercase;letter-spacing:.05em;color:#5a6582;font-weight:600">Tags (comma-separated)<input type="text" id="fTags" placeholder="Fiduciary, Tax Planning" style="width:100%;padding:8px 10px;border:1px solid #d7dce7;border-radius:6px;margin-top:4px" /></label>
        </div>
      </form>
    </div>
  </main>

  {/* Full-screen media picker modal */}
  <div id="mediaModal" class="modal-backdrop hidden" role="dialog" aria-modal="true">
    <div class="modal-head">
      <h2 id="modalTitle">Select image</h2>
      <button type="button" id="modalCloseBtn">Close (Esc)</button>
    </div>
    <div class="modal-body">
      <div class="modal-grid" id="modalGrid"></div>
    </div>
  </div>

  {/* Config (images/videos/repo) */}
  <script type="application/json" id="config" set:html={JSON.stringify(config)}></script>

  {/* One JSON blob per article, keyed by slug */}
  {articles.map((a) => (
    <script type="application/json" class="art" data-slug={a.slug} set:html={JSON.stringify(a)}></script>
  ))}

  <script is:inline>
    (function () {
      const CONFIG = JSON.parse(document.getElementById('config').textContent);
      const ARTS = {};
      document.querySelectorAll('script.art').forEach((el) => {
        ARTS[el.dataset.slug] = JSON.parse(el.textContent);
      });
      const LS_PAT = 'wf_admin_pat';
      const $ = (id) => document.getElementById(id);
      let currentView = 'gate';
      let suppressPopstate = false;

      function show(view) {
        $('gate').classList.toggle('hidden', view !== 'gate');
        $('listView').classList.toggle('hidden', view !== 'list');
        $('editView').classList.toggle('hidden', view !== 'edit');
        currentView = view;
        window.scrollTo(0, 0);
      }
      function flash(el, msg, kind) {
        el.innerHTML = msg ? '<div class="flash ' + (kind || 'ok') + '">' + String(msg).replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</div>' : '';
      }

      function stringifyFrontmatter(data, body) {
        const order = ['title','description','pubDate','daysAgo','author','tags','heroImage','heroVideo','draft'];
        const keys = Array.from(new Set(order.filter((k) => k in data).concat(Object.keys(data))));
        const lines = ['---'];
        for (const k of keys) {
          const v = data[k];
          if (v === undefined || v === '' || v === null) continue;
          if (Array.isArray(v)) lines.push(k + ': [' + v.map((x) => '"' + x + '"').join(', ') + ']');
          else if (k === 'pubDate' || k === 'daysAgo' || k === 'draft') lines.push(k + ': ' + v);
          else if (typeof v === 'string' && (v.indexOf(':') >= 0 || v.indexOf('"') >= 0)) lines.push(k + ': "' + String(v).replace(/"/g, '\\"') + '"');
          else lines.push(k + ': "' + v + '"');
        }
        lines.push('---'); lines.push('');
        return lines.join('\n') + body.replace(/^\r?\n/, '');
      }
      function b64(str) { return btoa(unescape(encodeURIComponent(str))); }

      // Update body-floated photo + store path
      function setCurrentImage(path, userAction) {
        $('fHeroImage').value = path || '';
        const img = $('aeHeroImage');
        const wrap = $('aeImgWrap');
        if (path) {
          img.src = path;
          img.style.display = 'block';
          wrap.classList.remove('empty');
          wrap.innerHTML = '<img id="aeHeroImage" class="article-hero-float" alt="" src="' + path + '" /><span class="ae-img-hint">🖼 Click to change</span>';
        } else {
          wrap.classList.add('empty');
          wrap.innerHTML = '🖼<br />Click to select an image';
        }
        if (userAction) markDirty();
      }
      function setCurrentVideo(path, userAction) {
        $('fHeroVideo').value = path || '';
        if (userAction) markDirty();
        const vid = $('aeHeroVideo');
        const note = $('aeVideoNote');
        const displayPath = path || (editing && editing.autoVideo) || (composing && CONFIG.videos[0] ? '/videos/' + CONFIG.videos[0] : '');
        if (displayPath) {
          vid.src = displayPath;
          vid.style.display = 'block';
          try { vid.load(); vid.play().catch(() => {}); } catch (e) {}
        } else {
          vid.removeAttribute('src');
          vid.style.display = 'none';
        }
        if (path) {
          note.textContent = 'Video: ' + path.split('/').pop() + ' (pinned)';
        } else if (displayPath) {
          note.textContent = 'Video: auto-picked ' + displayPath.split('/').pop();
        } else {
          note.textContent = '';
        }
      }

      // Full-screen picker modal. Opening the modal pushes a history entry
      // so the browser Back button closes the modal (rather than firing the
      // edit-view popstate save).
      let modalMode = null; // 'image' | 'video'
      function openModal(mode) {
        modalMode = mode;
        suppressPopstate = true;
        try { history.pushState({ view: 'modal', mode }, '', location.hash); }
        finally { setTimeout(() => { suppressPopstate = false; }, 0); }
        const isImage = mode === 'image';
        $('modalTitle').textContent = isImage ? 'Select image' : 'Select video';
        const files = isImage ? CONFIG.images : CONFIG.videos;
        const current = isImage ? $('fHeroImage').value : $('fHeroVideo').value;
        const grid = $('modalGrid');
        grid.innerHTML = '';

        if (!isImage) {
          // "None" tile only for videos (image is required)
          const none = document.createElement('div');
          none.className = 'modal-tile none' + (!current ? ' selected' : '');
          none.innerHTML = '<div class="media">None — no video</div><div class="caption">(no video)</div>';
          none.addEventListener('click', () => { setCurrentVideo('', true); closeModal(); });
          grid.appendChild(none);
        }

        files.forEach((f) => {
          const fullPath = (isImage ? '/images/' : '/videos/') + f;
          const tile = document.createElement('div');
          tile.className = 'modal-tile' + (fullPath === current ? ' selected' : '');
          if (isImage) {
            tile.innerHTML = '<img class="media" src="' + fullPath + '" alt="" loading="lazy"><div class="caption">' + f + '</div>';
          } else {
            tile.innerHTML = '<video class="media" src="' + fullPath + '" muted playsinline preload="metadata"></video><div class="caption">' + f + '</div>';
          }
          tile.addEventListener('click', () => {
            if (isImage) setCurrentImage(fullPath, true); else setCurrentVideo(fullPath, true);
            closeModal();
          });
          grid.appendChild(tile);
        });

        $('mediaModal').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }
      function closeModal(fromPopstate) {
        $('mediaModal').classList.add('hidden');
        document.body.style.overflow = '';
        modalMode = null;
        // If we opened with a pushState, pop it when closing by UI so the
        // browser history stays clean. If closeModal was triggered by a
        // popstate (user hit Back), skip — the pop already happened.
        if (!fromPopstate) {
          suppressPopstate = true;
          try { history.back(); }
          finally { setTimeout(() => { suppressPopstate = false; }, 20); }
        }
      }

      let editing = null;
      let composing = false;
      let dirty = false;
      function markDirty() { dirty = true; }

      function slugify(s) {
        return String(s || '').toLowerCase()
          .replace(/[^a-z0-9\s-]/g, '')
          .trim()
          .replace(/\s+/g, '-')
          .replace(/-+/g, '-')
          .slice(0, 80);
      }

      function formatDateForDisplay(ymd) {
        if (!ymd) return '';
        const d = new Date(ymd);
        if (isNaN(d.getTime())) return ymd;
        return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
      }

      function openEdit(slug) {
        const a = ARTS[slug];
        if (!a) return;
        editing = a;
        composing = false;
        dirty = false;
        $('saveBtn').textContent = 'Save & Deploy';
        $('slugRow').classList.add('hidden');
        $('editSlug').value = slug;
        $('fTitle').value = a.title || '';
        $('fDesc').value = a.description || '';
        $('aeTitle').textContent = a.title || '';
        $('aeDesc').textContent = a.description || '';
        $('aeCrumbTitle').textContent = a.title || '';
        $('aeEyebrow').textContent = (a.tags && a.tags[0]) || '';
        $('aeDateLabel').textContent = formatDateForDisplay(a.pubDate);
        $('aeAuthorLabel').textContent = a.author || 'Wilco Financial';
        $('aeTagsLabel').textContent = (a.tags || []).join(' · ');
        $('fDate').value = a.pubDate || '';
        $('fAuthor').value = a.author || 'Wilco Financial';
        $('fTags').value = (a.tags || []).join(', ');
        $('aeBody').innerHTML = renderMarkdown(a.body || '');
        setCurrentImage(a.heroImage || '');
        setCurrentVideo(a.heroVideo || '');
        flash($('editFlash'), '', 'ok');
        pushEditState(slug);
        show('edit');
      }

      function openCompose() {
        editing = null;
        composing = true;
        dirty = false;
        $('saveBtn').textContent = 'Create & Deploy';
        $('slugRow').classList.remove('hidden');
        $('editSlug').value = '';
        $('fSlug').value = '';
        $('fTitle').value = '';
        $('fDesc').value = '';
        $('aeTitle').textContent = '';
        $('aeDesc').textContent = '';
        $('aeCrumbTitle').textContent = '(new article)';
        $('aeEyebrow').textContent = '';
        const today = new Date().toISOString().slice(0, 10);
        $('aeDateLabel').textContent = formatDateForDisplay(today);
        $('aeAuthorLabel').textContent = 'Wilco Financial';
        $('aeTagsLabel').textContent = '';
        $('fDate').value = today;
        $('fAuthor').value = 'Wilco Financial';
        $('fTags').value = '';
        $('aeBody').innerHTML = '';
        setCurrentImage('');
        setCurrentVideo('');
        flash($('editFlash'), '', 'ok');
        pushEditState('__new__');
        show('edit');
      }

      // Contenteditable → hidden input sync (title/desc are plain text)
      function syncTitle() { $('fTitle').value = $('aeTitle').textContent.trim(); $('aeCrumbTitle').textContent = $('fTitle').value; markDirty(); }
      function syncDesc() { $('fDesc').value = $('aeDesc').textContent.trim(); markDirty(); }
      $('aeTitle').addEventListener('input', syncTitle);
      $('aeDesc').addEventListener('input', syncDesc);
      // Mark dirty on any secondary-field edit
      ['fDate','fAuthor','fTags'].forEach((id) => { const el = $(id); if (el) el.addEventListener('input', markDirty); });
      $('aeEyebrow').addEventListener('input', () => {
        // First tag follows the eyebrow
        const current = $('fTags').value.split(',').map((t) => t.trim()).filter(Boolean);
        const newFirst = $('aeEyebrow').textContent.trim();
        if (current[0] !== newFirst) {
          current[0] = newFirst;
          $('fTags').value = current.filter(Boolean).join(', ');
          $('aeTagsLabel').textContent = current.filter(Boolean).join(' · ');
        }
      });
      $('aeDateLabel').addEventListener('blur', () => {
        const t = $('aeDateLabel').textContent.trim();
        const d = new Date(t);
        if (!isNaN(d.getTime())) $('fDate').value = d.toISOString().slice(0, 10);
      });
      $('aeAuthorLabel').addEventListener('input', () => { $('fAuthor').value = $('aeAuthorLabel').textContent.trim(); });
      $('aeTagsLabel').addEventListener('input', () => {
        // Labels in body use " · " separator; frontmatter uses ", "
        const tags = $('aeTagsLabel').textContent.split(/[·,]/).map((t) => t.trim()).filter(Boolean);
        $('fTags').value = tags.join(', ');
        $('aeEyebrow').textContent = tags[0] || '';
      });

      // Prevent rich-text paste from injecting styles in single-line fields
      function plainTextPaste(e) {
        e.preventDefault();
        const text = (e.clipboardData || window.clipboardData).getData('text/plain');
        document.execCommand('insertText', false, text);
      }
      $('aeTitle').addEventListener('paste', plainTextPaste);
      $('aeDesc').addEventListener('paste', plainTextPaste);
      $('aeEyebrow').addEventListener('paste', plainTextPaste);
      $('aeDateLabel').addEventListener('paste', plainTextPaste);
      $('aeAuthorLabel').addEventListener('paste', plainTextPaste);
      $('aeTagsLabel').addEventListener('paste', plainTextPaste);
      // Single-line: Enter moves focus, doesn't newline
      ['aeTitle','aeDesc','aeEyebrow','aeDateLabel','aeAuthorLabel','aeTagsLabel'].forEach((id) => {
        $(id).addEventListener('keydown', (e) => { if (e.key === 'Enter') { e.preventDefault(); const next = { aeTitle:'aeDesc', aeDesc:'aeBody', aeEyebrow:'aeTitle', aeDateLabel:'aeAuthorLabel', aeAuthorLabel:'aeTagsLabel', aeTagsLabel:'aeBody' }[id]; if (next) $(next).focus(); } });
      });

      // Body paste: keep plain text to prevent Google Docs/Word junk
      $('aeBody').addEventListener('paste', (e) => {
        e.preventDefault();
        const text = (e.clipboardData || window.clipboardData).getData('text/plain');
        // Insert as paragraphs so Enter works as expected
        document.execCommand('insertText', false, text);
      });

      // Markdown → HTML (used to render the body on load)
      function renderMarkdown(md) {
        if (!md) return '<p style="color:#5a6582;font-style:italic">(empty body)</p>';
        const lines = md.replace(/\r\n/g, '\n').split('\n');
        const out = [];
        let inList = null; // 'ul' | 'ol' | null
        let buf = [];
        const flushPara = () => {
          if (buf.length) {
            out.push('<p>' + inline(buf.join(' ').trim()) + '</p>');
            buf = [];
          }
        };
        const flushList = () => { if (inList) { out.push('</' + inList + '>'); inList = null; } };
        const escHtml = (s) => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
        const inline = (s) => {
          s = escHtml(s);
          s = s.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
          s = s.replace(/\*([^*]+)\*/g, '<em>$1</em>');
          s = s.replace(/`([^`]+)`/g, '<code>$1</code>');
          s = s.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>');
          return s;
        };
        for (const raw of lines) {
          const line = raw;
          if (/^---+$/.test(line.trim())) { flushPara(); flushList(); out.push('<hr />'); continue; }
          if (/^#{1,6}\s+/.test(line)) {
            flushPara(); flushList();
            const m = line.match(/^(#+)\s+(.*)$/);
            const level = Math.min(m[1].length, 4);
            out.push('<h' + level + '>' + inline(m[2]) + '</h' + level + '>');
            continue;
          }
          const ulM = line.match(/^\s*[-*]\s+(.*)$/);
          const olM = line.match(/^\s*\d+\.\s+(.*)$/);
          if (ulM || olM) {
            flushPara();
            const kind = ulM ? 'ul' : 'ol';
            if (inList !== kind) { flushList(); out.push('<' + kind + '>'); inList = kind; }
            out.push('<li>' + inline((ulM || olM)[1]) + '</li>');
            continue;
          }
          if (line.trim() === '') { flushPara(); flushList(); continue; }
          buf.push(line);
        }
        flushPara(); flushList();
        return out.join('\n');
      }
      // HTML → Markdown serializer for the contenteditable body. Round-trips
      // the subset used in Wilco articles: headings (h2/h3/h4), bold, italic,
      // code, links, ul/ol, hr, paragraphs. Anything else falls through as
      // plain text.
      function htmlToMarkdown(root) {
        const inline = (node) => {
          if (node.nodeType === 3) return node.textContent;
          if (node.nodeType !== 1) return '';
          const tag = node.tagName;
          const kids = Array.from(node.childNodes).map(inline).join('');
          if (tag === 'STRONG' || tag === 'B') return '**' + kids + '**';
          if (tag === 'EM' || tag === 'I') return '*' + kids + '*';
          if (tag === 'CODE') return '`' + kids + '`';
          if (tag === 'A') return '[' + kids + '](' + (node.getAttribute('href') || '') + ')';
          if (tag === 'BR') return '\n';
          return kids;
        };
        const block = (node) => {
          if (node.nodeType === 3) {
            const t = node.textContent.replace(/\s+/g, ' ').trim();
            return t ? t : '';
          }
          if (node.nodeType !== 1) return '';
          const tag = node.tagName;
          if (tag === 'H1') return '# ' + inline(node).trim();
          if (tag === 'H2') return '## ' + inline(node).trim();
          if (tag === 'H3') return '### ' + inline(node).trim();
          if (tag === 'H4') return '#### ' + inline(node).trim();
          if (tag === 'HR') return '---';
          if (tag === 'UL') return Array.from(node.children).map((li) => '- ' + inline(li).trim()).join('\n');
          if (tag === 'OL') return Array.from(node.children).map((li, i) => (i + 1) + '. ' + inline(li).trim()).join('\n');
          if (tag === 'BLOCKQUOTE') return '> ' + inline(node).trim();
          if (tag === 'P' || tag === 'DIV') return inline(node).trim();
          return inline(node).trim();
        };
        // Walk top-level children and emit blocks separated by blank lines
        const blocks = [];
        Array.from(root.childNodes).forEach((n) => {
          const b = block(n);
          if (b !== '') blocks.push(b);
        });
        return blocks.join('\n\n');
      }

      // Keep the hidden markdown field in sync on every body edit
      $('aeBody').addEventListener('input', () => {
        $('fBody').value = htmlToMarkdown($('aeBody'));
        markDirty();
      });

      // Auto-fill slug from title while composing (until user edits slug manually)
      let slugManual = false;
      const fSlug = $('fSlug');
      if (fSlug) fSlug.addEventListener('input', () => { slugManual = true; });
      $('aeTitle').addEventListener('input', () => {
        if (composing && !slugManual && fSlug) fSlug.value = slugify($('aeTitle').textContent);
      });

      // Poll the live article URL until the new content appears. The admin
      // and the live site are same-origin so this is a plain fetch. We look
      // for the saved title and description in the returned HTML. Gives up
      // after 10 minutes.
      let livePollToken = 0;
      async function pollLive(slug, expected, stillRelevant) {
        const myToken = ++livePollToken;
        const liveUrl = '/articles/' + slug + '/';
        const started = Date.now();
        const statusEl = () => document.getElementById('livePollStatus');
        const esc = (s) => String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        const check = async () => {
          if (myToken !== livePollToken) return; // superseded by a newer save
          if (stillRelevant && !stillRelevant()) return; // flash is gone
          const elapsed = Math.round((Date.now() - started) / 1000);
          if (elapsed > 600) {
            const s = statusEl(); if (s) s.innerHTML = '<strong>Still waiting after 10 min.</strong> Check <a href="https://vercel.com/jgillett987s-projects/wilcofin" target="_blank" rel="noopener" style="color:#011342;text-decoration:underline">Vercel deployments</a>.';
            return;
          }
          try {
            const res = await fetch(liveUrl + '?_=' + Date.now(), { cache: 'no-store' });
            if (res.ok) {
              const html = await res.text();
              // Match on the *exact* saved title or description (rendered into
              // the page as <h1> text and <meta name="description">). Use a
              // loose-ish contains check that tolerates HTML entities.
              const needle = esc(expected.title) || '';
              const needleDesc = esc(expected.description) || '';
              const live = (needle && html.indexOf(needle) !== -1) ||
                           (needleDesc && html.indexOf(needleDesc) !== -1);
              if (live) {
                const s = statusEl(); if (s) s.innerHTML = '<strong>✓ Live on the site</strong> after ' + elapsed + 's.';
                return;
              }
            }
          } catch (err) { /* network blip — keep polling */ }
          const s = statusEl(); if (s) s.textContent = 'Waiting for Vercel to redeploy… ' + elapsed + 's';
          setTimeout(check, 8000);
        };
        setTimeout(check, 8000); // first check after 8s; GitHub→Vercel handoff is ~10-30s
      }

      async function saveArticle(e) {
        if (e && e.preventDefault) e.preventDefault();
        syncTitle(); syncDesc();
        // Ensure latest body markdown is captured
        $('fBody').value = htmlToMarkdown($('aeBody'));
        const pat = localStorage.getItem(LS_PAT);
        if (!pat) { show('gate'); return false; }
        const btn = $('saveBtn');
        const labelDefault = composing ? 'Create & Deploy' : 'Save & Deploy';
        btn.disabled = true; btn.textContent = composing ? 'Creating…' : 'Saving…';
        try {
          let slug;
          if (composing) {
            slug = slugify($('fSlug').value || $('fTitle').value);
            if (!slug) throw new Error('Slug is required.');
            if (!/^[a-z0-9-]+$/.test(slug)) throw new Error('Slug must be lowercase letters, numbers, and dashes only.');
            if (ARTS[slug]) throw new Error('An article with slug "' + slug + '" already exists.');
          } else {
            if (!editing) return;
            slug = editing.slug;
          }

          const data = {
            title: $('fTitle').value,
            description: $('fDesc').value,
            pubDate: $('fDate').value || (editing && editing.pubDate) || new Date().toISOString().slice(0,10),
            author: $('fAuthor').value || 'Wilco Financial',
            tags: $('fTags').value.split(',').map((t) => t.trim()).filter(Boolean),
            heroImage: $('fHeroImage').value || (editing && editing.heroImage) || '',
          };
          if (composing && !data.heroImage) throw new Error('Hero image is required.');
          const heroVideo = $('fHeroVideo').value;
          if (heroVideo) data.heroVideo = heroVideo;
          else delete data.heroVideo;

          const out = stringifyFrontmatter(data, '\n' + $('fBody').value);
          const filePath = 'src/content/articles/' + slug + '.md';
          const url = 'https://api.github.com/repos/' + CONFIG.repo + '/contents/' + filePath;

          // Always fetch a fresh SHA (cache-busted) — stale SHAs cause 409s
          async function fetchSha() {
            const bust = '&_=' + Date.now();
            const getRes = await fetch(url + '?ref=' + encodeURIComponent(CONFIG.branch) + bust, {
              cache: 'no-store',
              headers: { Authorization: 'Bearer ' + pat, Accept: 'application/vnd.github+json' },
            });
            if (!getRes.ok) {
              if (getRes.status === 404) return null; // file doesn't exist yet
              throw new Error('GET failed: ' + getRes.status + ' ' + (await getRes.text()).slice(0, 200));
            }
            const meta = await getRes.json();
            return meta.sha;
          }

          let sha = composing ? null : await fetchSha();

          async function doPut(withSha) {
            const putBody = {
              message: (composing ? 'Add article: ' : 'Edit article: ') + slug + ' (via admin)',
              content: b64(out),
              branch: CONFIG.branch,
            };
            if (withSha) putBody.sha = withSha;
            return fetch(url, {
              method: 'PUT',
              headers: { Authorization: 'Bearer ' + pat, Accept: 'application/vnd.github+json', 'Content-Type': 'application/json' },
              body: JSON.stringify(putBody),
            });
          }

          let putRes = await doPut(sha);
          // 409 = SHA conflict; re-fetch fresh SHA and retry once.
          if (putRes.status === 409 && !composing) {
            console.warn('[admin] 409 SHA mismatch — retrying with fresh SHA');
            const fresh = await fetchSha();
            if (fresh && fresh !== sha) {
              sha = fresh;
              putRes = await doPut(sha);
            }
          }
          if (!putRes.ok) {
            const txt = (await putRes.text()).slice(0, 400);
            console.error('[admin] GitHub PUT rejected', putRes.status, txt);
            if (putRes.status === 403 || /not accessible by personal access token/i.test(txt)) {
              throw new Error('GitHub rejected the save (403). Your Personal Access Token does not have write access to this repo. Fix: go to github.com/settings/personal-access-tokens, edit the token, set "Repository permissions → Contents" to "Read and write" for jgillett987/wilcofin, then Sign Out of this admin and paste the new token.');
            }
            if (putRes.status === 409) {
              throw new Error('GitHub rejected the save (409 SHA mismatch). The file changed on the server since this page loaded. Reload the admin page to pick up the latest version, then try again.');
            }
            throw new Error('PUT failed: ' + putRes.status + ' ' + txt);
          }

          const putJson = await putRes.json();
          const commitUrl = (putJson && putJson.commit && putJson.commit.html_url) || '';
          const commitSha = (putJson && putJson.commit && putJson.commit.sha) || '';
          console.log('[admin] Save succeeded:', slug, commitUrl);

          if (composing) {
            ARTS[slug] = { slug, body: $('fBody').value, ...data };
          } else {
            Object.assign(editing, data, { body: $('fBody').value, heroVideo: heroVideo });
          }
          dirty = false;

          // Stay on the edit view and show a clear, verifiable success state.
          const commitBit = commitUrl
            ? ' · <a href="' + commitUrl + '" target="_blank" rel="noopener" style="color:#011342;text-decoration:underline"><code>' + (commitSha ? commitSha.slice(0, 7) : 'commit') + '</code> on GitHub</a>'
            : '';
          const liveUrl = '/articles/' + slug + '/';
          const viewBit = ' · <a href="' + liveUrl + '" target="_blank" rel="noopener" style="color:#011342;text-decoration:underline">View article ↗</a>';
          const baseFlash = '<div class="flash ok">✓ Saved <strong>' + slug + '.md</strong>' + commitBit + viewBit;
          $('editFlash').innerHTML = baseFlash + ' · <span id="livePollStatus">Waiting for Vercel to redeploy (typically 30–90s)…</span></div>';
          const savedLabel = composing ? 'Created ✓' : 'Saved ✓';
          btn.textContent = savedLabel;
          setTimeout(() => { if (btn.textContent === savedLabel) btn.textContent = labelDefault; }, 2000);
          // Kick off a poll of the live URL; tell the user the moment the
          // new content is actually visible on the production site.
          pollLive(slug, {
            title: data.title,
            description: data.description,
          }, () => $('editFlash').innerHTML.includes(slug)); // keep polling only while this flash is current
          return true;
        } catch (err) {
          flash($('editFlash'), String(err.message || err), 'err');
          return false;
        } finally {
          btn.disabled = false; btn.textContent = labelDefault;
        }
      }

      // ── History / browser-back = save and return to list ────────────────
      function pushEditState(slug) {
        suppressPopstate = true;
        try { history.pushState({ view: 'edit', slug }, '', '#edit/' + slug); }
        finally { setTimeout(() => { suppressPopstate = false; }, 0); }
      }
      function returnToList() {
        suppressPopstate = true;
        try {
          // Replace whatever edit / modal hash is in the URL with the clean
          // list URL, so subsequent Back presses don't bounce back into edit.
          history.replaceState({ view: 'list' }, '', location.pathname + location.search);
        } finally { setTimeout(() => { suppressPopstate = false; }, 0); }
        show('list');
        window.scrollTo(0, 0);
      }
      window.addEventListener('popstate', async () => {
        if (suppressPopstate) return;
        // If a picker is open, the Back just closes it.
        if (modalMode) { closeModal(true); return; }
        if (currentView === 'edit') {
          // Browser Back from edit → try to save, but always return to the
          // list. If the save fails, carry the error into the list flash so
          // the user can see it and isn't trapped.
          const ok = await saveArticle();
          const errHtml = ok ? '' : $('editFlash').innerHTML;
          returnToList();
          if (errHtml) $('flash').innerHTML = errHtml;
        }
      });

      // Row-level + button-level Edit handlers. Click anywhere on the row
      // to open the article; the green Edit button still works (and its
      // click is stopped from bubbling so it doesn't fire twice).
      document.querySelectorAll('tr[data-edit]').forEach((tr) => {
        tr.addEventListener('click', () => openEdit(tr.getAttribute('data-edit')));
      });
      document.querySelectorAll('button[data-edit]').forEach((btn) => {
        btn.addEventListener('click', (e) => { e.stopPropagation(); openEdit(btn.getAttribute('data-edit')); });
      });
      $('composeBtn').addEventListener('click', openCompose);

      $('gateForm').addEventListener('submit', (e) => {
        e.preventDefault();
        const pat = $('patInput').value.trim();
        if (!pat) return;
        localStorage.setItem(LS_PAT, pat);
        $('patInput').value = '';
        show('list');
      });
      $('cancelBtn').addEventListener('click', () => returnToList());
      $('backBtn').addEventListener('click', async () => {
        // "Back to list" tries to save, but always returns. If the save
        // fails (e.g. GitHub PAT 403), show the error on the list so the
        // user isn't trapped on the edit view.
        const ok = await saveArticle();
        if (!ok) {
          const errHtml = $('editFlash').innerHTML;
          returnToList();
          $('flash').innerHTML = errHtml || '<div class="flash err">Save failed — your changes were not written.</div>';
        } else {
          returnToList();
        }
      });
      $('editForm').addEventListener('submit', saveArticle);
      $('signOutBtn').addEventListener('click', () => {
        localStorage.removeItem(LS_PAT);
        show('gate');
      });

      // Click-to-change: video fires only when the click target is the hero
      // background itself — not the title/desc/breadcrumb/eyebrow/tag links
      // inside .container. Those remain editable / navigable.
      $('aeHero').addEventListener('click', (e) => {
        if (e.target.closest('.container')) return; // editing text
        if (e.target.closest('a')) return;
        openModal('video');
      });
      $('aeImgWrap').addEventListener('click', () => openModal('image'));
      $('heroVideoChangeBtn').addEventListener('click', (e) => { e.preventDefault(); openModal('video'); });
      $('heroVideoClearBtn').addEventListener('click', (e) => { e.preventDefault(); setCurrentVideo('', true); });

      $('modalCloseBtn').addEventListener('click', closeModal);
      $('mediaModal').addEventListener('click', (e) => { if (e.target.id === 'mediaModal') closeModal(); });

      // Prev/next navigation between articles (matches live-site order: newest first)
      function navigateRelative(delta) {
        if (!editing) return;
        const order = CONFIG.orderedSlugs || [];
        const idx = order.indexOf(editing.slug);
        if (idx < 0) return;
        const target = order[idx + delta];
        if (!target) return;
        // If there are no unsaved edits, jump instantly — no network trip.
        if (!dirty) {
          pushEditState(target);
          openEdit(target);
          return;
        }
        // Otherwise save first so work isn't lost
        saveArticle().finally(() => {
          pushEditState(target);
          openEdit(target);
        });
      }
      $('aePrevBtn').addEventListener('click', (e) => { e.preventDefault(); navigateRelative(1); }); // older = index+1
      $('aeNextBtn').addEventListener('click', (e) => { e.preventDefault(); navigateRelative(-1); }); // newer = index-1

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modalMode) { closeModal(); return; }
        // Arrow-key navigation between articles — only when focus isn't in a
        // text field / contenteditable (so normal cursor movement is preserved).
        if (currentView === 'edit' && !modalMode && (e.key === 'ArrowLeft' || e.key === 'ArrowRight')) {
          const ae = document.activeElement;
          const inEditable = ae && (
            ae.tagName === 'INPUT' ||
            ae.tagName === 'TEXTAREA' ||
            ae.tagName === 'SELECT' ||
            (ae.getAttribute && ae.getAttribute('contenteditable') === 'true')
          );
          if (inEditable) return;
          e.preventDefault();
          navigateRelative(e.key === 'ArrowLeft' ? 1 : -1); // Left = older, Right = newer
        }
      });


      // Initial view — restore edit deep-link if present
      const hashMatch = location.hash.match(/^#edit\/([\w-]+|__new__)$/);
      if (!localStorage.getItem(LS_PAT)) {
        show('gate');
      } else if (hashMatch) {
        if (hashMatch[1] === '__new__') openCompose();
        else openEdit(hashMatch[1]);
      } else {
        show('list');
      }
    })();
  </script>
</body>
</html>

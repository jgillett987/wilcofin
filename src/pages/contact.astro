---
import PageLayout from '../layouts/PageLayout.astro';
import PrevNext from '../components/PrevNext.astro';
import { CONTACT, SITE } from '../consts';

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  url: new URL('/contact', Astro.site).toString(),
  about: { '@id': `${SITE.url}#organization` },
};
---
<PageLayout
  title="Contact Wilco Financial"
  description="Schedule a meeting, call (615) 237-8750, or email info@wilcofin.com. Based in Williamson County, Tennessee — serving Tennessee clients and select clients in other states where permitted."
  eyebrow="Contact"
  heroTitle="Let's start a conversation"
  heroSubtitle="No pressure, no sales pitch — just a straightforward chat about what you're trying to accomplish."
  breadcrumbs={[{ label: 'Contact' }]}
  heroVideo="/videos/04.mp4"
  structuredData={contactSchema}
>
  <section class="section">
    <div class="container split">
      <div>
        <h2>Reach out</h2>
        <p><strong>Phone</strong><br /><a href={CONTACT.phoneHref}>{CONTACT.phone}</a></p>
        <p><strong>Email</strong><br /><a href={CONTACT.emailHref}>{CONTACT.email}</a></p>
        <p><strong>Mailing Address</strong><br />
          {CONTACT.addressLine1}, {CONTACT.addressLine2}<br />
          {CONTACT.city}, {CONTACT.state} {CONTACT.zip}
        </p>
        <p><strong>Hours</strong><br />{CONTACT.hours}</p>
        <p style="margin-top:28px;">
          <a href={CONTACT.calendlyUrl} class="btn btn-primary" target="_blank" rel="noopener">Schedule a Meeting</a>
        </p>
      </div>
      <div>
        <div class="card">
          <h3 style="margin-top:0;">What happens when you reach out</h3>
          <ol style="padding-left:1.2em; line-height:1.7; margin-bottom:0;">
            <li style="margin-bottom:10px;"><strong>A short intro call.</strong> 15–30 minutes by phone or video. We talk about what you're trying to accomplish and what's been getting in the way. No pitch, no paperwork.</li>
            <li style="margin-bottom:10px;"><strong>A written proposal, if it's a fit.</strong> If we think we can help, you get a plain-language summary of what we'd do, what you'd pay, and how we'd work together.</li>
            <li style="margin-bottom:10px;"><strong>You decide — no pressure.</strong> Take as long as you need. If it's not the right fit on either side, we'll say so and point you toward something that is.</li>
          </ol>
          <hr style="border:none; border-top:1px solid var(--border); margin:20px 0;" />
          <p style="margin:0; font-size:0.95rem; color:var(--muted);">
            Our fee is a flat <strong style="color:var(--navy);">{SITE.fee}/year</strong> of assets under management
            (<strong style="color:var(--navy);">{SITE.swaEffectiveFee}</strong> for Southwest Airlines employees and pilots).
            Client assets are custodied independently at <strong style="color:var(--navy);">Charles Schwab</strong>,
            in accounts titled in the client's name.
          </p>
        </div>
      </div>
    </div>
  </section>

  <PrevNext section="about" />
</PageLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../../components/CTA.astro';
import { render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import { SITE } from '../../consts';
import { getPublishedArticles } from '../../lib/articles';

// Pool of hero videos — one is picked per article based on a hash of the slug,
// so the same article always gets the same video but articles vary across the set.
const HERO_VIDEOS = [
  '/videos/00.mp4',
  '/videos/01.mp4',
  '/videos/02.mp4',
  '/videos/03.mp4',
  '/videos/04.mp4',
  '/videos/05.mp4',
  '/videos/06.mp4',
  '/videos/08.mp4',
  '/videos/10.mp4',
  '/videos/14.mp4',
];

const pickVideo = (slug: string) => {
  let h = 0;
  for (let i = 0; i < slug.length; i++) h = (h * 31 + slug.charCodeAt(i)) >>> 0;
  return HERO_VIDEOS[h % HERO_VIDEOS.length];
};

export const getStaticPaths: GetStaticPaths = async () => {
  const articles = await getPublishedArticles();
  return articles.map((article, i) => ({
    params: { slug: article.id },
    props: {
      article,
      prev: i < articles.length - 1 ? { label: articles[i + 1].data.title, href: `/articles/${articles[i + 1].id}` } : null,
      next: i > 0 ? { label: articles[i - 1].data.title, href: `/articles/${articles[i - 1].id}` } : null,
    },
  }));
};

const { article, prev, next } = Astro.props;
const { Content } = await render(article);
const heroVideo = article.data.heroVideo ?? pickVideo(article.id);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.data.title,
  description: article.data.description,
  datePublished: article.data.pubDate.toISOString(),
  dateModified: (article.data.updatedDate ?? article.data.pubDate).toISOString(),
  author: {
    '@type': 'Organization',
    name: article.data.author,
    url: SITE.url,
  },
  publisher: { '@id': `${SITE.url}#organization` },
  mainEntityOfPage: new URL(`/articles/${article.id}`, SITE.url).toString(),
  keywords: article.data.tags.join(', '),
};

const breadcrumbsSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url + '/' },
    { '@type': 'ListItem', position: 2, name: 'Articles', item: SITE.url + '/articles' },
    { '@type': 'ListItem', position: 3, name: article.data.title },
  ],
};

const formattedDate = article.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout
  title={article.data.title}
  description={article.data.description}
  image={article.data.heroImage}
  type="article"
  publishedTime={article.data.pubDate}
  modifiedTime={article.data.updatedDate}
  author={article.data.author}
  structuredData={[articleSchema, breadcrumbsSchema]}
>
  <section class="page-hero page-hero-with-video-bg">
    <video class="page-hero-bg-video" autoplay muted loop playsinline preload="auto" aria-hidden="true">
      <source src={heroVideo} type="video/mp4" />
    </video>
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a> / <a href="/articles">Articles</a> / <span>{article.data.title}</span>
      </nav>
      {article.data.tags.length > 0 && <span class="eyebrow">{article.data.tags[0]}</span>}
      <h1>{article.data.title}</h1>
      <p>{article.data.description}</p>
    </div>
  </section>

  <section class="section">
    <div class="article-container">
      <div class="article-meta-row">
        <div>
          <p class="article-meta" style="font-size:0.9rem; text-transform:uppercase; letter-spacing:0.06em; font-weight:700; color:var(--muted); margin-bottom:8px;">
            {formattedDate} · {article.data.author}
          </p>
          {article.data.tags.length > 0 && (
            <p style="margin-bottom:0; font-size:0.9rem;">
              {article.data.tags.map((t, i) => {
                const slug = t.toLowerCase().replace(/\s+/g, '-');
                return (
                  <>
                    {i > 0 && ' · '}
                    <a href={`/articles/tag/${slug}`}>{t}</a>
                  </>
                );
              })}
            </p>
          )}
        </div>
        <div class="article-top-nav">
          <button type="button" class="article-top-nav-btn article-pdf-btn" data-article-pdf aria-label="Download as PDF" title="Download as branded PDF">↓ PDF</button>
          {prev && (
            <a href={prev.href} class="article-top-nav-btn" data-prev-next="prev" aria-label={`Older: ${prev.label}`} title={`← ${prev.label}`}>← Prev</a>
          )}
          {next && (
            <a href={next.href} class="article-top-nav-btn" data-prev-next="next" aria-label={`Newer: ${next.label}`} title={`${next.label} →`}>Next →</a>
          )}
        </div>
      </div>

      {/* Print-only branded header — hidden on screen, shown at top of PDF */}
      <div class="print-only print-header" aria-hidden="true">
        <img src="/logo-color.png" alt="Wilco Financial" class="print-logo" />
        <div class="print-header-right">
          <div class="print-site">wilcofin.com</div>
          <div class="print-tag">Fiduciary investment management & financial planning</div>
        </div>
      </div>
      <div class="print-only print-title-block" aria-hidden="true">
        {article.data.tags.length > 0 && <div class="print-eyebrow">{article.data.tags[0]}</div>}
        <h1 class="print-title">{article.data.title}</h1>
        <p class="print-desc">{article.data.description}</p>
        <div class="print-byline">{formattedDate} · {article.data.author}</div>
      </div>

      <article class="article-body prose">
        {article.data.heroImage && (
          <img class="article-hero-float" src={article.data.heroImage} alt="" loading="lazy" />
        )}
        <Content />
      </article>

      {/* Print-only footer — last page of PDF */}
      <div class="print-only print-footer" aria-hidden="true">
        <div class="print-footer-brand">
          <strong>Wilco Financial, LLC</strong><br />
          6688 Nolensville Rd, Ste 108 #3029 · Brentwood, TN 37027<br />
          (615) 237-8750 · info@wilcofin.com · wilcofin.com
        </div>
        <div class="print-disclaimer">
          Wilco Financial, LLC is a state-registered investment adviser and fiduciary. This article is general educational content, not personalized investment, tax, or legal advice. Consult a qualified professional for advice about your specific situation.
        </div>
      </div>
    </div>
  </section>

  {(prev || next) && (
    <nav class="prev-next" aria-label="Article navigation">
      <div class="container narrow">
        <div class="prev-next-grid">
          <div>
            {prev && (
              <a href={prev.href} class="prev-next-link prev-next-prev" data-prev-next="prev">
                <span class="prev-next-arrow" aria-hidden="true">←</span>
                <span class="prev-next-text">
                  <span class="prev-next-meta">Older</span>
                  <span class="prev-next-label">{prev.label}</span>
                </span>
              </a>
            )}
          </div>
          <div class="prev-next-right">
            {next && (
              <a href={next.href} class="prev-next-link prev-next-next" data-prev-next="next">
                <span class="prev-next-text">
                  <span class="prev-next-meta">Newer</span>
                  <span class="prev-next-label">{next.label}</span>
                </span>
                <span class="prev-next-arrow" aria-hidden="true">→</span>
              </a>
            )}
          </div>
        </div>
      </div>
    </nav>
  )}

  <CTA
    title="Have questions about what you just read?"
    subtitle="Let's have a short conversation — no pressure, no sales pitch."
  />

  <script is:inline define:vars={{ articleTitle: article.data.title }}>
    (function () {
      const btn = document.querySelector('[data-article-pdf]');
      if (!btn) return;
      btn.addEventListener('click', () => {
        // Browsers use document.title as the default PDF filename.
        const originalTitle = document.title;
        const clean = String(articleTitle).replace(/[\\/:*?"<>|]+/g, '').slice(0, 120);
        document.title = 'Wilco Financial — ' + clean;
        const restore = () => { document.title = originalTitle; window.removeEventListener('afterprint', restore); };
        window.addEventListener('afterprint', restore);
        window.print();
        // Safari / some browsers don't fire afterprint reliably — restore after a delay too.
        setTimeout(restore, 3000);
      });
    })();
  </script>
</BaseLayout>
